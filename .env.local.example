# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OG 이미지: 공개 버킷 short_site(기본)에 short_og/default.png 업로드, 또는 아래에 전체 URL 지정
NEXT_PUBLIC_OG_STORAGE_BUCKET=short_site
# NEXT_PUBLIC_OG_IMAGE_URL=https://...

# JWT 비밀키 (랜덤 64자 이상 문자열 사용)
JWT_SECRET=your_jwt_secret_here_change_this_to_random_string

# 기본 URL
NEXT_PUBLIC_BASE_URL=https://숏.한국/
